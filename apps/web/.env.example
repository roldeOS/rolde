# RolDe web — environment template. Copy to .env.local and fill in.
# Supabase (rolde-dev). The publishable/anon key is safe for the browser;
# the service-role key is server-only and is NEVER placed here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Cloudflare Turnstile — PUBLIC site key (safe in the browser). The SECRET key is
# configured in Supabase Auth (CAPTCHA), never here.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Resend — SERVER-ONLY API key for transactional email (never browser-exposed).
RESEND_API_KEY=
